{
  "headers": [
    {
      "source": "/",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/((?!assets/|favicon|icon\\.svg|robots\\.txt|manifest\\.webmanifest|sw\\.js|workbox-|polyfills\\.js).*)",
      "destination": "/index.html"
    }
  ]
}